ge locations over time =C2=B7 10 rows returned</div><pre>WITH product_pairs=
 AS (
  SELECT=20
    sod1.productid AS product1_id,
    p1.name AS product1_name,
    sod2.productid AS product2_id,
    p2.name AS product2_name,
    pi1.locationid AS location1_id,
    loc1.name AS location1_name,
    pi2.locationid AS location2_id,
    loc2.name AS location2_name,
    soh.orderdate,
    DATE_TRUNC('month', soh.orderdate::date) AS order_month,
    COUNT(*) AS co_purchase_count,
    SUM(sod1.linetotal + sod2.linetotal) AS pair_revenue
  FROM sales.sales_order_detail sod1
  INNER JOIN sales.sales_order_detail sod2=20
    ON sod1.salesorderid =3D sod2.salesorderid=20
    AND sod1.productid &lt; sod2.productid
  INNER JOIN sales.sales_order_header soh=20
    ON sod1.salesorderid =3D soh.salesorderid
  INNER JOIN production.product p1=20
    ON sod1.productid =3D p1.productid
  INNER JOIN production.product p2=20
    ON sod2.productid =3D p2.productid
  INNER JOIN production.product_inventory pi1=20
    ON sod1.productid =3D pi1.productid
  INNER JOIN production.product_inventory pi2=20
    ON sod2.productid =3D pi2.productid
  INNER JOIN production.location loc1=20
    ON pi1.locationid =3D loc1.locationid
  INNER JOIN production.location loc2=20
    ON pi2.locationid =3D loc2.locationid
  WHERE pi1.locationid &lt;&gt; pi2.locationid
    AND soh.status =3D 5
  GROUP BY=20
    sod1.productid, p1.name,
    sod2.productid, p2.name,
    pi1.locationid, loc1.name,
    pi2.locationid, loc2.name,
    soh.orderdate,
    DATE_TRUNC('month', soh.orderdate::date)
),
ranked_pairs AS (
  SELECT=20
    product1_id,
    product1_name,
    product2_id,
    product2_name,
    location1_name,
    location2_name,
    order_month,
    SUM(co_purchase_count) AS total_co_purchases,
    SUM(pair_revenue) AS total_revenue,
    ROW_NUMBER() OVER (
      ORDER BY SUM(co_purchase_count) DESC
    ) AS pair_rank
  FROM product_pairs
  GROUP BY=20
    product1_id, product1_name,
    product2_id, product2_name,
    location1_name, location2_name,
    order_month
)
SELECT=20
  product1_name,
  product2_name,
  location1_name,
  location2_name,
  order_month,
  total_co_purchases,
  ROUND(total_revenue::numeric, 2) AS total_revenue
FROM ranked_pairs
WHERE pair_rank &lt;=3D 10
ORDER BY total_co_purchases DESC, order_month
LIMIT 200</pre></div><div class=3D"sql-query-block"><div class=3D"sql-query=
-meta">Top 10 product pairs sold together from different storage locations,=
 aggregated by month over time =C2=B7 215 rows returned</div><pre>WITH prod=
uct_pairs AS (
  SELECT=20
    sod1.productid AS product1_id,
    p1.name AS product1_name,
    sod2.productid AS product2_id,
    p2.name AS product2_name,
    pi1.locationid AS location1_id,
    loc1.name AS location1_name,
    pi2.locationid AS location2_id,
    loc2.name AS location2_name,
    DATE_TRUNC('month', soh.orderdate::date) AS order_month,
    COUNT(*) AS co_purchase_count,
    SUM(sod1.linetotal + sod2.linetotal) AS pair_revenue
  FROM sales.sales_order_detail sod1
  INNER JOIN sales.sales_order_detail sod2=20
    ON sod1.salesorderid =3D sod2.salesorderid=20
    AND sod1.productid &lt; sod2.productid
  INNER JOIN sales.sales_order_header soh=20
    ON sod1.salesorderid =3D soh.salesorderid
  INNER JOIN production.product p1=20
    ON sod1.productid =3D p1.productid
  INNER JOIN production.product p2=20
    ON sod2.productid =3D p2.productid
  INNER JOIN production.product_inventory pi1=20
    ON sod1.productid =3D pi1.productid
  INNER JOIN production.product_inventory pi2=20
    ON sod2.productid =3D pi2.productid
  INNER JOIN production.location loc1=20
    ON pi1.locationid =3D loc1.locationid
  INNER JOIN production.location loc2=20
    ON pi2.locationid =3D loc2.locationid
  WHERE pi1.locationid &lt;&gt; pi2.locationid
    AND soh.status =3D 5
  GROUP BY=20
    sod1.productid, p1.name,
    sod2.productid, p2.name,
    pi1.locationid, loc1.name,
    pi2.locationid, loc2.name,
    DATE_TRUNC('month', soh.orderdate::date)
),
pair_totals AS (
  SELECT=20
    product1_name || ' + ' || product2_name AS pair_name,
    order_month,
    SUM(co_purchase_count) AS total_co_purchases
  FROM product_pairs
  GROUP BY=20
    product1_name || ' + ' || product2_name,
    order_month
),
top_pairs AS (
  SELECT=20
    pair_name,
    SUM(total_co_purchases) AS all_time_purchases,
    ROW_NUMBER() OVER (ORDER BY SUM(total_co_purchases) DESC) AS rank
  FROM pair_totals
  GROUP BY pair_name
)
SELECT=20
  pt.pair_name,
  pt.order_month,
  pt.total_co_purchases
FROM pair_totals pt
INNER JOIN top_pairs tp ON pt.pair_name =3D tp.pair_name
WHERE tp.rank &lt;=3D 10
ORDER BY tp.rank, pt.order_month</pre></div></div>
