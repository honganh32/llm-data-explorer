flow for Sankey visualization =C2=B7 46 rows returned</div><pre>WITH sales_=
flow AS (
  SELECT=20
    st.name AS territory,
    pc.name AS category,
    p.name AS product,
    SUM(sod.linetotal) AS revenue
  FROM sales.sales_order_header soh
  JOIN sales.sales_order_detail sod ON soh.salesorderid =3D sod.salesorderi=
d
  JOIN production.product p ON sod.productid =3D p.productid
  JOIN production.product_subcategory psc ON p.productsubcategoryid =3D psc=
.productsubcategoryid
  JOIN production.product_category pc ON psc.productcategoryid =3D pc.produ=
ctcategoryid
  JOIN sales.sales_territory st ON soh.territoryid =3D st.territoryid
  WHERE soh.status =3D 5
  GROUP BY st.name, pc.name, p.name
)
-- Territory =E2=86=92 Category aggregation (top 8 territories, top 4 categ=
ories)
SELECT 'territory_category' AS flow_type,
       territory AS source,
       category AS target,
       SUM(revenue)::BIGINT AS value
FROM sales_flow
WHERE territory IN (
  SELECT territory FROM sales_flow GROUP BY territory ORDER BY SUM(revenue)=
 DESC LIMIT 8
)
AND category IN (
  SELECT category FROM sales_flow GROUP BY category ORDER BY SUM(revenue) D=
ESC LIMIT 4
)
GROUP BY territory, category

UNION ALL

-- Category =E2=86=92 Product aggregation (top 5 products per category)
SELECT 'category_product' AS flow_type,
       category AS source,
       product AS target,
       SUM(revenue)::BIGINT AS value
FROM (
  SELECT category, product, revenue,
         ROW_NUMBER() OVER (PARTITION BY category ORDER BY revenue DESC) AS=
 rn
  FROM sales_flow
  WHERE category IN (
    SELECT category FROM sales_flow GROUP BY category ORDER BY SUM(revenue)=
 DESC LIMIT 4
  )
) ranked
WHERE rn &lt;=3D 5
GROUP BY category, product
ORDER BY value DESC;</pre></div></div>
